<?xml version="1.0" encoding="utf-8"?>
<Peach xmlns="http://peachfuzzer.com/2012/Peach" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <Defaults>
        <Number endian="big" signed="false" />
    </Defaults>

    <DataModel name="dtls_protocol_version_t">
        <Number name="major" size="8" value="254" />
        <Number name="minor" size="8" value="253" />
    </DataModel>

    <DataModel name="dtls_session_id_t">
        <Number name="len" size="8">
            <Relation type="size" of="id" />
        </Number>
        <Blob name="id" />
    </DataModel>

    <DataModel name="dtls_extensions_block_t">
        <Number name="total_len" size="16">
            <Relation type="size" of="raw" />
        </Number>
        <Blob name="raw" />
    </DataModel>

    <DataModel name="dtls_signature_and_hash_t">
        <Number name="hash_algorithm" size="8" />
        <Number name="signature_algorithm" size="8" />
    </DataModel>

    <DataModel name="dtls_digitally_signed_t">
        <Block name="alg" ref="dtls_signature_and_hash_t" />
        <Number name="signature_len" size="16">
            <Relation type="size" of="signature" />
        </Number>
        <Blob name="signature" />
    </DataModel>

    <DataModel name="dtls_client_hello_t">
        <Block name="client_version" ref="dtls_protocol_version_t" />
        <Blob name="random" length="32" />
        <Block name="session_id" ref="dtls_session_id_t" />
        <Number name="cookie_len" size="8">
            <Relation type="size" of="cookie" />
        </Number>
        <Blob name="cookie"  />
        <Number name="cipher_suites_len" size="16">
            <Relation type="size" of="cipher_suites" />
        </Number>
        <Blob name="cipher_suites" />
        <Number name="compression_methods_len" size="8">
            <Relation type="size" of="compression_methods" />
        </Number>
        <Blob name="compression_methods" />
        <Block name="extensions" ref="dtls_extensions_block_t" minOccurs="0" maxOccurs="1" />
    </DataModel>

    <DataModel name="dtls_server_hello_t">
        <Block name="server_version" ref="dtls_protocol_version_t" />
        <Blob name="random" length="32" />
        <Block name="session_id" ref="dtls_session_id_t" />
        <Number name="cipher_suite" size="16" />
        <Number name="compression_method" size="8" />
        <Block name="extensions" ref="dtls_extensions_block_t" minOccurs="0" maxOccurs="1" />
    </DataModel>

    <DataModel name="dtls_hello_verify_request_t">
        <Block name="server_version" ref="dtls_protocol_version_t" />
        <Number name="cookie_len" size="8">
            <Relation type="size" of="cookie" />
        </Number>
        <Blob name="cookie" />
    </DataModel>

    <DataModel name="dtls_certificate_body_t">
        <Number name="cert_blob_len" size="24">
            <Relation type="size" of="cert_blob" />
        </Number>
        <Blob name="cert_blob" />
    </DataModel>

    <DataModel name="dtls_server_dh_params_t">
        <Number name="dh_p_len" size="16"><Relation type="size" of="dh_p" /></Number>
        <Blob name="dh_p" />
        <Number name="dh_g_len" size="16"><Relation type="size" of="dh_g" /></Number>
        <Blob name="dh_g" />
        <Number name="dh_Ys_len" size="16"><Relation type="size" of="dh_Ys" /></Number>
        <Blob name="dh_Ys" />
    </DataModel>

    <DataModel name="dtls_ecdh_server_params_t">
        <Number name="curve_type" size="8" />
        <Number name="named_curve" size="16" />
        <Number name="ec_point_len" size="8"><Relation type="size" of="ec_point" /></Number>
        <Blob name="ec_point" />
    </DataModel>

    <DataModel name="dtls_server_key_exchange_body_t">
        <Choice name="u">
            <Block name="dh_anon" ref="dtls_server_dh_params_t" />
            <Block name="dhe_signed">
                <Block name="params" ref="dtls_server_dh_params_t" />
                <Block name="sig" ref="dtls_digitally_signed_t" />
            </Block>
            <Block name="ecdhe_signed">
                <Block name="params" ref="dtls_ecdh_server_params_t" />
                <Block name="sig" ref="dtls_digitally_signed_t" />
            </Block>
            <Block name="psk">
                <Number name="identity_hint_len" size="16"><Relation type="size" of="identity_hint" /></Number>
                <Blob name="identity_hint" />
            </Block>
        </Choice>
    </DataModel>

    <DataModel name="dtls_certificate_request_t">
        <Number name="cert_types_len" size="8"><Relation type="size" of="cert_types" /></Number>
        <Blob name="cert_types" />
        <Number name="sig_algs_len" size="16"><Relation type="size" of="sig_algs" /></Number>
        <Blob name="sig_algs" />
        <Number name="ca_dn_len" size="16"><Relation type="size" of="ca_dn_blob" /></Number>
        <Blob name="ca_dn_blob" />
    </DataModel>

    <DataModel name="dtls_client_key_exchange_body_t">
        <Choice name="u">
            <Block name="ecdh" constraint="int(self.Children()[0].DefaultValue) + 1 == int(self.parent.parent.parent.find('length').DefaultValue)">
                <Number name="ec_point_len" size="8">
                    <Relation type="size" of="ec_point" />
                </Number>
                <Blob name="ec_point" />
            </Block>

            <Block name="psk">
                <Number name="identity_len" size="16"><Relation type="size" of="identity" /></Number>
                <Blob name="identity" />
            </Block>

            <Block name="dh">
                <Number name="dh_Yc_len" size="16"><Relation type="size" of="dh_Yc" /></Number>
                <Blob name="dh_Yc" />
            </Block>

            <Block name="rsa">
                <Number name="enc_pms_len" size="16"><Relation type="size" of="enc_pms" /></Number>
                <Blob name="enc_pms" />
            </Block>

            <Block name="dhe_psk">
                <Number name="identity_len" size="16"><Relation type="size" of="identity" /></Number>
                <Blob name="identity" />
                <Number name="dh_Yc_len" size="16"><Relation type="size" of="dh_Yc" /></Number>
                <Blob name="dh_Yc" />
            </Block>

            <Block name="rsa_psk">
                <Number name="identity_len" size="16"><Relation type="size" of="identity" /></Number>
                <Blob name="identity" />
                <Number name="enc_pms_len" size="16"><Relation type="size" of="enc_pms" /></Number>
                <Blob name="enc_pms" />
            </Block>

            <Block name="ecdhe_psk">
                <Number name="identity_len" size="16"><Relation type="size" of="identity" /></Number>
                <Blob name="identity" />
                <Number name="ec_point_len" size="8"><Relation type="size" of="ec_point" /></Number>
                <Blob name="ec_point" />
            </Block>
        </Choice>
    </DataModel>

    <DataModel name="dtls_certificate_verify_body_t">
        <Block name="alg" ref="dtls_signature_and_hash_t" />
        <Number name="signature_len" size="16"><Relation type="size" of="signature" /></Number>
        <Blob name="signature" />
    </DataModel>

    <DataModel name="dtls_finished_body_t">
        <Blob name="verify_data" length="12" />
    </DataModel>

    <DataModel name="dtls_handshake_all">
        <Choice name="handshake_messages">
            <Choice name="non_encrypted" constraint="self.root.find('ccs_record').parent.SelectedElement != self.root.find('ccs_record')">
                <Block name="hello_request">
                    <Number name="msg_type" size="8" value="0" token="true" />
                    <Number name="length" size="24" value="0" />
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24" value="0" />
                </Block>
                <Block name="client_hello">
                    <Number name="msg_type" size="8" value="1" token="true" />
                    <Number name="length" size="24"><Relation type="size" of="body" /></Number>
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24"><Relation type="size" of="body" /></Number>
                    <Block name="body" ref="dtls_client_hello_t" />
                </Block>
                <Block name="server_hello">
                    <Number name="msg_type" size="8" value="2" token="true" />
                    <Number name="length" size="24"><Relation type="size" of="body" /></Number>
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24"><Relation type="size" of="body" /></Number>
                    <Block name="body" ref="dtls_server_hello_t" />
                </Block>
                <Block name="hello_verify_request">
                    <Number name="msg_type" size="8" value="3" token="true" />
                    <Number name="length" size="24"><Relation type="size" of="body" /></Number>
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24"><Relation type="size" of="body" /></Number>
                    <Block name="body" ref="dtls_hello_verify_request_t" />
                </Block>
                <Block name="certificate">
                    <Number name="msg_type" size="8" value="11" token="true" />
                    <Number name="length" size="24"><Relation type="size" of="body" /></Number>
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24"><Relation type="size" of="body" /></Number>
                    <Block name="body" ref="dtls_certificate_body_t" />
                </Block>
                <Block name="server_key_exchange">
                    <Number name="msg_type" size="8" value="12" token="true" />
                    <Number name="length" size="24"><Relation type="size" of="body" /></Number>
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24"><Relation type="size" of="body" /></Number>
                    <Block name="body" ref="dtls_server_key_exchange_body_t" />
                </Block>
                <Block name="certificate_request">
                    <Number name="msg_type" size="8" value="13" token="true" />
                    <Number name="length" size="24"><Relation type="size" of="body" /></Number>
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24"><Relation type="size" of="body" /></Number>
                    <Block name="body" ref="dtls_certificate_request_t" />
                </Block>
                <Block name="server_hello_done">
                    <Number name="msg_type" size="8" value="14" token="true" />
                    <Number name="length" size="24" value="0" />
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24" value="0" />
                </Block>
                <Block name="certificate_verify">
                    <Number name="msg_type" size="8" value="15" token="true" />
                    <Number name="length" size="24"><Relation type="size" of="body" /></Number>
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24"><Relation type="size" of="body" /></Number>
                    <Block name="body" ref="dtls_certificate_verify_body_t" />
                </Block>
                <Block name="client_key_exchange">
                    <Number name="msg_type" size="8" value="16" token="true" />
                    <Number name="length" size="24"><Relation type="size" of="body" /></Number>
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24"><Relation type="size" of="body" /></Number>
                    <Block name="body" ref="dtls_client_key_exchange_body_t" />
                </Block>
                <Block name="finished">
                    <Number name="msg_type" size="8" value="20" token="true" />
                    <Number name="length" size="24"><Relation type="size" of="body" /></Number>
                    <Number name="message_seq" size="16" />
                    <Number name="fragment_offset" size="24" value="0" />
                    <Number name="fragment_length" size="24"><Relation type="size" of="body" /></Number>
                    <Block name="body" ref="dtls_finished_body_t" />
                </Block>
            </Choice>
            <Block name="encrypted" constraint="self.root.find('ccs_record').parent.SelectedElement == self.root.find('ccs_record')">
                <Blob name="data" />
            </Block>
        </Choice>
    </DataModel>

    <DataModel name="dtls_packet_t">
        <Choice name="dtls_record">
            
            <Block name="handshake_record">
                <Number name="type" size="8" value="22" token="true" />
                <Block name="header_common">
                    <Number name="version_major" size="8" value="254" />
                    <Number name="version_minor" size="8" value="253" />
                    <Number name="epoch" size="16" />
                    <Number name="sequence_number" size="48" />
                </Block>
                <Number name="length" size="16">
                    <Relation type="size" of="handshake_data" />
                </Number>
                <Block name="handshake_data" ref="dtls_handshake_all" />
            </Block>

            <Block name="ccs_record">
                <Number name="type" size="8" value="20" token="true" />
                <Block name="header_common">
                    <Number name="version_major" size="8" value="254" />
                    <Number name="version_minor" size="8" value="253" />
                    <Number name="epoch" size="16" />
                    <Number name="sequence_number" size="48" />
                </Block>
                <Number name="length" size="16">
                    <Relation type="size" of="ccs_body" />
                </Number>
                <Block name="ccs_body">
                    <Number name="value" size="8" value="1" />
                </Block>
            </Block>

            <Block name="alert_record">
                <Number name="type" size="8" value="21" token="true" />
                <Block name="header_common">
                    <Number name="version_major" size="8" value="254" />
                    <Number name="version_minor" size="8" value="253" />
                    <Number name="epoch" size="16" />
                    <Number name="sequence_number" size="48" />
                </Block>
                <Number name="length" size="16">
                    <Relation type="size" of="alert_body" />
                </Number>
                <Block name="alert_body">
                    <Number name="level" size="8" />
                    <Number name="description" size="8" />
                </Block>
            </Block>

            <Block name="app_data_record">
                <Number name="type" size="8" value="23" token="true" />
                <Block name="header_common">
                    <Number name="version_major" size="8" value="254" />
                    <Number name="version_minor" size="8" value="253" />
                    <Number name="epoch" size="16" />
                    <Number name="sequence_number" size="48" />
                </Block>
                <Number name="length" size="16">
                    <Relation type="size" of="app_data" />
                </Number>
                <Blob name="app_data" />
            </Block>

        </Choice>
    </DataModel>

    <DataModel name="dtls_packet_array">
        <Block name="packets" minOccurs="1" maxOccurs="100">
            <Block name="dtls_packet" ref="dtls_packet_t">
            </Block>
        </Block>
    </DataModel>

    <StateModel name="TheState" initialState="Initial">
        <State name="Initial">
            <Action type="outputPackets">
                <DataModel ref="dtls_packet_array"/>
                <!-- <Data fileName="./seed/*.raw" /> -->
            </Action>
        </State>
    </StateModel>

    <Test name="Default">
        <StateModel ref="TheState"/>

        <Publisher class="Udp">
            <Param name="Host" value="host.docker.internal"/>
            <Param name="Port" value="20220"/>
            <Param name="Timeout" value="200"/>
        </Publisher>

        <Strategy class="Random" />

    </Test>
</Peach>