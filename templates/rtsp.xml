<?xml version="1.0" encoding="utf-8"?>

<Peach xmlns="http://peachfuzzer.com/2012/Peach" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://peachfuzzer.com/2012/Peach /peach/peach.xsd">

    <Defaults>
        <Number signed="false" endian="big"/>
    </Defaults>

    <!-- RTSP White Space -->
    <DataModel name="RTSP_SP">
        <String name="sp" value=" " token="true" mutable="false"/>
    </DataModel>

    <DataModel name="RTSP_CRLF">
        <String name="crlf" value="\r\n" token="true" mutable="false"/>
    </DataModel>

    <!-- RTSP ASCII Number -->
    <DataModel name="RTSP_AsciiNumber">
        <String name="num" type="ascii"/>
    </DataModel>

    <DataModel name="rtsp_uri_union_t">
        <Choice name="request_union">
            <!-- URI 不定长度，读取到下一个空格 token 为止 -->
            <String name="action" token="true" type="ascii"/>
        </Choice>
    </DataModel>

    <!-- RTSP Request Line：METHOD SP URI SP RTSP/1.0 CRLF -->
    <DataModel name="rtsp_request_line_t">
        <String name="method" token="true"/>
        <String name="sp" value=" " token="true" mutable="false"/>
        <String name="uri" type="ascii">
            <Analyzer class="StringToken">
                <Param name="Tokens" value=" "/>
            </Analyzer>
        </String>
        <String name="sp1" value=" " token="true" mutable="false"/>
        <String name="version" value="RTSP/1.0" token="true" mutable="false"/>
        <Block ref="RTSP_CRLF" mutable="false"/>
    </DataModel>

    <!-- General Request Headers：CSeq / User-Agent -->
    <DataModel name="rtsp_common_request_headers_t">
        <String name="cseq_name" value="CSeq:" token="true"/>
        <Block ref="RTSP_SP"/>
        <String name="cseq" type="ascii"/>
        <Block ref="RTSP_CRLF"/>

        <String name="ua_name" value="User-Agent:" token="true"/>
        <Block ref="RTSP_SP"/>
        <String name="user_agent" value="Peach-RTSP-Fuzzer/1.0"/>
        <Block ref="RTSP_CRLF"/>
    </DataModel>

    <!-- Session Headers -->
    <DataModel name="rtsp_header_session_t">
        <String name="session_name" value="Session:" token="true"/>
        <Block ref="RTSP_SP"/>
        <String name="session_id" value="12345678"/>
        <Block ref="RTSP_CRLF"/>
    </DataModel>

    <!-- DESCRIBE Accept header: application/sdp -->
    <DataModel name="rtsp_header_accept_sdp_t">
        <String name="h_accept_name" value="Accept:" token="true"/>
        <Block ref="RTSP_SP"/>
        <String name="accept" value="application/sdp" token="true"/>
        <Block ref="RTSP_CRLF"/>
    </DataModel>

    <!-- SETUP Transport header -->
    <DataModel name="rtsp_header_transport_t">
        <String name="h_transport_name" value="Transport:" token="true"/>
        <Block ref="RTSP_SP"/>
        <String name="transport" value="RTP/AVP;unicast;client_port=8000-8001;mode=play"/>
        <Block ref="RTSP_CRLF"/>
    </DataModel>

    <!-- PLAY Range header -->
    <DataModel name="rtsp_header_range_t">
        <String name="h_range_name" value="Range:" token="true"/>
        <Block ref="RTSP_SP"/>
        <String name="range" value="npt=0-"/>
        <Block ref="RTSP_CRLF"/>
    </DataModel>

    <!-- Content-Type -->
    <DataModel name="rtsp_header_content_type_t">
        <String name="h_ct_name" value="Content-Type:" token="true"/>
        <Block ref="RTSP_SP"/>
        <String name="content_type" value="text/parameters"/>
        <Block ref="RTSP_CRLF"/>
    </DataModel>

    <!-- Content-Length -->
    <DataModel name="rtsp_header_content_length_t">
        <String name="h_cl_name" value="Content-Length:" token="true"/>
        <Block ref="RTSP_SP"/>
        <String name="content_length" type="ascii">
            <Relation type="size" of="msg_body"/>
        </String>
        <Block ref="RTSP_CRLF"/>
    </DataModel>

    <DataModel name="rtsp_end_headers_t">
        <Block ref="RTSP_CRLF"/>
    </DataModel>


    <!-- =========================
         RTSP 各类请求 Packet
         每个 packet：request_line + common_headers + (method-specific headers) + end_headers + (optional body)
         ========================= -->

    <!-- OPTIONS -->
    <DataModel name="rtsp_options_request_t">
        <Block name="request_line" ref="rtsp_request_line_t">
            <String name="method" value="OPTIONS" token="true"/>
        </Block>

        <Block name="common_headers" ref="rtsp_common_request_headers_t"/>

        <Block name="end_headers" ref="rtsp_end_headers_t"/>
    </DataModel>

    <!-- DESCRIBE -->
    <DataModel name="rtsp_describe_request_t">
        <Block name="request_line" ref="rtsp_request_line_t">
            <String name="method" value="DESCRIBE" token="true"/>
        </Block>

        <Block name="common_headers" ref="rtsp_common_request_headers_t"/>

        <Block name="accept" ref="rtsp_header_accept_sdp_t"/>

        <Block name="end_headers" ref="rtsp_end_headers_t"/>
    </DataModel>

    <!-- SETUP（常见 track URL） -->
    <DataModel name="rtsp_setup_request_t">
        <Block name="request_line" ref="rtsp_request_line_t">
            <String name="method" value="SETUP" token="true"/>
        </Block>

        <Block name="common_headers" ref="rtsp_common_request_headers_t"/>

        <Block name="transport" ref="rtsp_header_transport_t"/>
        <Block name="session" ref="rtsp_header_session_t" minOccurs="0" maxOccurs="1"/>

        <Block name="end_headers" ref="rtsp_end_headers_t"/>
    </DataModel>

    <!-- PLAY -->
    <DataModel name="rtsp_play_request_t">
        <Block name="request_line" ref="rtsp_request_line_t">
            <String name="method" value="PLAY" token="true"/>
        </Block>

        <Block name="common_headers" ref="rtsp_common_request_headers_t"/>

        <Block name="session" ref="rtsp_header_session_t"/>

        <Block name="range" ref="rtsp_header_range_t"/>

        <Block name="end_headers" ref="rtsp_end_headers_t"/>
    </DataModel>

    <!-- PAUSE -->
    <DataModel name="rtsp_pause_request_t">
        <Block name="request_line" ref="rtsp_request_line_t">
            <String name="method" value="PAUSE" token="true"/>
        </Block>

        <Block name="common_headers" ref="rtsp_common_request_headers_t"/>

        <Block name="session" ref="rtsp_header_session_t"/>

        <Block name="end_headers" ref="rtsp_end_headers_t"/>
    </DataModel>

    <!-- GET_PARAMETER（常用 keep-alive；此处不带 body） -->
    <DataModel name="rtsp_get_parameter_request_t">
        <Block name="request_line" ref="rtsp_request_line_t">
            <String name="method" value="GET_PARAMETER" token="true"/>
        </Block>

        <Block name="common_headers" ref="rtsp_common_request_headers_t"/>

        <Block name="session" ref="rtsp_header_session_t"/>

        <Block name="end_headers" ref="rtsp_end_headers_t"/>

        <Block name="msg_body"/>
    </DataModel>

    <!-- SET_PARAMETER（带 body：需要 Content-Type + Content-Length；body 作为 Blob 方便变异） -->
    <DataModel name="rtsp_set_parameter_request_t">
        <Block name="request_line" ref="rtsp_request_line_t">
            <String name="method" value="SET_PARAMETER" token="true"/>
        </Block>

        <Block name="common_headers" ref="rtsp_common_request_headers_t"/>

        <Block name="session" ref="rtsp_header_session_t"/>

        <Block name="content_type" ref="rtsp_header_content_type_t"/>

        <!-- Content-Length 与 body 关联；body 定义在本 DataModel 内 -->
        <String name="h_cl_name" value="Content-Length:" token="true"/>
        <Block ref="RTSP_SP"/>
        <String name="content_length" type="ascii">
            <Relation type="size" of="body"/>
        </String>
        <Block ref="RTSP_CRLF"/>
        <Block name="end_headers" ref="rtsp_end_headers_t"/>
        <Blob name="body">
        </Blob>
    </DataModel>

    <!-- TEARDOWN -->
    <DataModel name="rtsp_teardown_request_t">
        <Block name="request_line" ref="rtsp_request_line_t">
            <String name="method" value="TEARDOWN" token="true"/>
        </Block>

        <Block name="common_headers" ref="rtsp_common_request_headers_t"/>

        <Block name="session" ref="rtsp_header_session_t"/>

        <Block name="end_headers" ref="rtsp_end_headers_t"/>
    </DataModel>


    <!-- =========================
         rtsp_request_t - Union（Choice）
         ========================= -->
    <DataModel name="rtsp_request_t">
        <Choice name="request_union">
            <Block name="options" ref="rtsp_options_request_t"/>
            <Block name="describe" ref="rtsp_describe_request_t"/>
            <Block name="setup" ref="rtsp_setup_request_t"/>
            <Block name="play" ref="rtsp_play_request_t"/>
            <Block name="pause" ref="rtsp_pause_request_t"/>
            <Block name="get_parameter" ref="rtsp_get_parameter_request_t"/>
            <Block name="set_parameter" ref="rtsp_set_parameter_request_t"/>
            <Block name="teardown" ref="rtsp_teardown_request_t"/>
        </Choice>
    </DataModel>

    <!-- rtsp_request_t[] - Array of RTSP requests -->
    <DataModel name="rtsp_request_array">
        <Block name="requests" minOccurs="1" maxOccurs="100">
            <Block ref="rtsp_request_t"/>
        </Block>
    </DataModel>


    <StateModel name="TheState" initialState="Initial">
        <State name="Initial">
            <Action type="output">
                <DataModel ref="rtsp_request_array"/>
                <Data fileName="/peach/Live555_Experiments/profuzzbench/subjects/RTSP/Live555/in-rtsp/*.raw" />
            </Action>
        </State>
    </StateModel>

    <Test name="Default">
        <StateModel ref="TheState"/>

            <!-- <Mutators mode="include">
                <Mutator class="DataElementSwapNearNodes" />
                <Mutator class="NumericalEdgeCaseMutator" />
                <Mutator class="NumericalVarianceMutator" />
                <Mutator class="BlobBitFlipperMutator" />
                <Mutator class="BlobDWORDSliderMutator" />
                <Mutator class="BlobMutator" />
                <Mutator class="StringCaseMutator" />
                <Mutator class="StringMutator" />
                <Mutator class="UnicodeStringMutator" />
                <Mutator class="UnicodeUtf8ThreeCharMutator" />
                <Mutator class="UnicodeBadUtf8Mutator" />
            </Mutators> -->

            <Publisher class="TcpClient">
                <Param name="Host" value="127.0.0.1"/>
                <Param name="Port" value="8554"/>
                <Param name="Timeout" value="200"/>
            </Publisher>

        <Strategy class="Random"/>

    </Test>

</Peach>